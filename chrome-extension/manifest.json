{
  "manifest_version": 3,
  "name": "Market Hours Alerts",
  "version": "1.0.0",
  "description": "Background market-opening gong and system notifications for Market Hours.",
  "minimum_chrome_version": "116",
  "permissions": [
    "alarms",
    "notifications",
    "offscreen",
    "storage"
  ],
  "host_permissions": [
    "https://agenteumanafastquotes.github.io/markethours/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_title": "Market Hours Alerts",
    "default_popup": "popup.html"
  }
}
